FROM ubuntu:22.04

LABEL maintainer="cpu-profiling-tool"
LABEL description="7x24 持续 CPU Profiling 工具 - Docker 镜像"

# 设置非交互式安装，避免 tzdata 等包卡在配置界面
ENV DEBIAN_FRONTEND=noninteractive

#-------------------------------------------------------------------------------
# 安装系统依赖
#   linux-tools-6.8.0-124-generic / linux-tools-common : perf 工具
#   python3 / python3-pip                      : Python 运行环境
#   git                                        : 克隆 FlameGraph 工具链
#   perl                                       : FlameGraph 脚本依赖
#   procps                                     : pgrep / pkill 进程管理
#   stress-ng                                  : CPU 压力测试验证
#-------------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    linux-tools-common \
    linux-tools-6.8.0-124-generic \
    python3 \
    python3-pip \
    git \
    perl \
    procps \
    stress-ng \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

#-------------------------------------------------------------------------------
# 设置工作目录
#-------------------------------------------------------------------------------
WORKDIR /app

#-------------------------------------------------------------------------------
# 复制项目文件
#-------------------------------------------------------------------------------
COPY src/ /app/src/
COPY requirements.txt /app/

#-------------------------------------------------------------------------------
# 安装 Python 依赖
#-------------------------------------------------------------------------------
RUN pip3 install --no-cache-dir -r requirements.txt

#-------------------------------------------------------------------------------
# 设置脚本执行权限
#-------------------------------------------------------------------------------
RUN chmod +x /app/src/*.sh /app/src/*.py

#-------------------------------------------------------------------------------
# 环境变量配置
#-------------------------------------------------------------------------------
ENV DATA_DIR=/data/perf_raw
ENV SVG_DIR=/data/perf_svg
ENV RETENTION_HOURS=24
ENV FLAMEGRAPH_DIR=/tmp/FlameGraph

#-------------------------------------------------------------------------------
# 创建数据目录
#-------------------------------------------------------------------------------
RUN mkdir -p /data/perf_raw /data/perf_svg

#-------------------------------------------------------------------------------
# 暴露 HTTP API 端口
#-------------------------------------------------------------------------------
EXPOSE 8080

#-------------------------------------------------------------------------------
# 容器入口点
#-------------------------------------------------------------------------------
ENTRYPOINT ["/bin/bash", "/app/src/entrypoint.sh"]
